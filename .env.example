# Copy this file to .env and fill in real values before deploying to production.

PORT=8080

# Secret used to sign dashboard login sessions (JWT). Generate a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# Seed admin account created on first run if no users exist yet.
ADMIN_EMAIL=admin@warden.local
ADMIN_PASSWORD=change-this-password

# Where the SQLite database file is stored.
DATA_DIR=./data
